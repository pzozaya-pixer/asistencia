# Shared
NODE_ENV=development
TZ=Europe/Madrid
TRUST_PROXY=true
CORS_ALLOWED_ORIGINS=http://localhost:3000,https://asistencia.agenciapixer.es

# Frontend
NEXT_PUBLIC_APP_NAME=Asistencia Demo
NEXT_PUBLIC_SUPABASE_URL=https://supabase.agenciapixer.es
NEXT_PUBLIC_SUPABASE_ANON_KEY=replace-me
API_INTERNAL_URL=http://api:4000/api/v1

# Backend
PORT=4000
API_PREFIX=api
JWT_ACCESS_SECRET=replace-with-strong-secret
JWT_REFRESH_SECRET=replace-with-strong-secret
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=7d
QR_SIGNING_SECRET=replace-with-strong-secret
AUTOMATION_SECRET=replace-with-strong-secret
RATE_LIMIT_WINDOW_SECONDS=60
RATE_LIMIT_MAX_LOGIN=5
RATE_LIMIT_MAX_REFRESH=10
RATE_LIMIT_MAX_AUTOMATION=30
DATABASE_URL=postgresql://postgres:postgres@postgres:5432/asistencia
DIRECT_URL=postgresql://postgres:postgres@postgres:5432/asistencia
MINIO_ENDPOINT=minio
MINIO_PORT=9000
MINIO_USE_SSL=false
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_PUBLIC_URL=
MINIO_SIGNED_URL_TTL=900
MINIO_BUCKET_ASSISTANTS=asistentes-fotos
MINIO_BUCKET_SIGNATURES=firmas
MINIO_BUCKET_PDFS=pdfs
MINIO_BUCKET_EXCELS=excels
MINIO_BUCKET_LOGS=logs

# PostgreSQL
POSTGRES_DB=asistencia
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres

# MinIO
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin
MINIO_CONSOLE_PORT=9001

# n8n
N8N_PORT=5678
N8N_PROTOCOL=http
N8N_HOST=localhost
N8N_EDITOR_BASE_URL=http://localhost:5678
N8N_ENCRYPTION_KEY=replace-with-strong-secret
N8N_USER_MANAGEMENT_JWT_SECRET=replace-with-strong-secret
N8N_BASIC_AUTH_ACTIVE=true
N8N_BASIC_AUTH_USER=admin
N8N_BASIC_AUTH_PASSWORD=admin
AUTOMATION_API_BASE_URL=http://api:4000/api/v1

# Backups
BACKUP_RETENTION_DAYS=14
RCLONE_REMOTE_NAME=backup-remote
RCLONE_REMOTE_PATH=/asistencia-demo
