# Supabase self-hosted for Dokploy
# Based on the official Supabase Docker stack.
# Replace every placeholder before production deployment.

POSTGRES_PASSWORD=replace-with-strong-password
JWT_SECRET=replace-with-strong-jwt-secret
ANON_KEY=replace-with-selfhosted-anon-key
SERVICE_ROLE_KEY=replace-with-selfhosted-service-role-key
DASHBOARD_USERNAME=admin
DASHBOARD_PASSWORD=replace-with-strong-dashboard-password
SECRET_KEY_BASE=replace-with-strong-secret-key-base

SITE_URL=https://supabase.agenciapixer.es
API_EXTERNAL_URL=https://supabase.agenciapixer.es
SUPABASE_PUBLIC_URL=https://supabase.agenciapixer.es

